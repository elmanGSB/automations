[Unit]
Description=Interview Router - Fireflies to NotebookLM
After=network.target xvfb.service

[Service]
Type=simple
User=REPLACE_WITH_USERNAME
WorkingDirectory=/home/REPLACE_WITH_USERNAME/interview-router
EnvironmentFile=/home/REPLACE_WITH_USERNAME/interview-router/.env
Environment=DISPLAY=:99
ExecStart=/usr/local/bin/uvicorn main:app --host 0.0.0.0 --port 8001
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
